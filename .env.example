# Shared defaults (copy to .env for local dev)

# Postgres connection used by Prisma in apps/api
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qr_loyalty?schema=public"

# Secrets used for signing tokens/sessions (use strong random values in real env)
CUSTOMER_SESSION_SECRET="change-me"
MERCHANT_SESSION_SECRET="change-me"
CUSTOMER_QR_SECRET="change-me"
