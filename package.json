{
  "name": "scoring-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n customer,api,merchant -c auto \"npm -w apps/customer run dev\" \"npm -w apps/api run dev\" \"npm -w apps/merchant run dev\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "db:generate": "npm --workspace apps/api run db:generate",
    "db:migrate": "npm --workspace apps/api run db:migrate",
    "db:seed": "npm --workspace apps/api run db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "concurrently": "^9.2.1"
  }
}
